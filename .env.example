# ─────────────────────────────────────────────────────────────────────────────
# Assiut School Management — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
ENV=development          # development | production

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=             # REQUIRED — change before deploying
DB_NAME=school_management
DB_SSLMODE=disable       # Use "require" or "verify-full" in production

# ── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED — must be at least 32 random characters in production.
# Generate: openssl rand -hex 32
JWT_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=          # REQUIRED in production
REDIS_DB=0

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=15

# ── SMTP (email delivery) ────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@school.example.com

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# ── Docker compose ports (optional overrides) ─────────────────────────────────
API_PORT=8080
WEB_PORT=3000
