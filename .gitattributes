# Normalize line endings to LF in the repo; checkout as-is on Windows.
* text=auto eol=lf

# Binary files — never mangle line endings.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
*.zip  binary
*.exe  binary
